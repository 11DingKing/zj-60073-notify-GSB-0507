generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChannelType {
  EMAIL
  SMS
  IN_APP
  WEBSOCKET
}

enum ProviderType {
  SMTP
  SENDGRID
  ALIYUN_SMS
  TENCENT_SMS
  INTERNAL
}

enum MessageStatus {
  PENDING
  SENDING
  SUCCESS
  FAILED
  RETRY
}

enum RetryStrategy {
  FIXED
  EXPONENTIAL
}

model Channel {
  id          String          @id @default(cuid())
  type        ChannelType
  name        String
  description String?
  isEnabled   Boolean         @default(true)
  config      Json
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  providers     ChannelProvider[]
  templates     TemplateChannel[]
  messages      Message[]
  preferences   UserPreference[]

  @@index([type])
  @@index([isEnabled])
}

model ChannelProvider {
  id          String          @id @default(cuid())
  channelId   String
  type        ProviderType
  name        String
  description String?
  isEnabled   Boolean         @default(true)
  config      Json
  priority    Int             @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  deletedAt   DateTime?

  channel   Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)
  messages  Message[]

  @@index([channelId])
  @@index([isEnabled])
  @@index([priority])
}

model Template {
  id            String            @id @default(cuid())
  code          String            @unique
  name          String
  description   String?
  type          String
  subject       String?
  content       String
  variables     Json              @default("[]")
  isEnabled     Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?

  versions    TemplateVersion[]
  channels    TemplateChannel[]
  messages    Message[]

  @@index([code])
  @@index([isEnabled])
}

model TemplateVersion {
  id          String          @id @default(cuid())
  templateId  String
  version     String
  subject     String?
  content     String
  variables   Json            @default("[]")
  createdAt   DateTime        @default(now())
  createdBy   String?

  template   Template   @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, version])
  @@index([templateId])
}

model TemplateChannel {
  id          String          @id @default(cuid())
  templateId  String
  channelId   String
  isEnabled   Boolean         @default(true)
  config      Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  template   Template   @relation(fields: [templateId], references: [id], onDelete: Cascade)
  channel    Channel    @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([templateId, channelId])
  @@index([templateId])
  @@index([channelId])
}

model Message {
  id              String          @id @default(cuid())
  templateId      String?
  channelId       String?
  providerId      String?
  recipient       String
  recipientId     String?
  subject         String?
  content         String
  variables       Json            @default("{}")
  status          MessageStatus   @default(PENDING)
  priority        Int             @default(0)
  retryCount      Int             @default(0)
  maxRetryCount   Int             @default(3)
  retryStrategy   RetryStrategy   @default(EXPONENTIAL)
  retryInterval   Int             @default(5000)
  errorMessage    String?
  sentAt          DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  template    Template?         @relation(fields: [templateId], references: [id], onDelete: SetNull)
  channel     Channel?          @relation(fields: [channelId], references: [id], onDelete: SetNull)
  provider    ChannelProvider?  @relation(fields: [providerId], references: [id], onDelete: SetNull)
  inAppMessage InAppMessage?

  @@index([recipient])
  @@index([recipientId])
  @@index([status])
  @@index([createdAt])
  @@index([sentAt])
  @@index([templateId])
  @@index([channelId])
  @@index([priority])
}

model InAppMessage {
  id          String      @id @default(cuid())
  messageId   String      @unique
  userId      String
  title       String?
  content     String
  isRead      Boolean     @default(false)
  readAt      DateTime?
  createdAt   DateTime    @default(now())

  message   Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model UserPreference {
  id              String          @id @default(cuid())
  userId          String
  channelId       String
  notificationType String
  isEnabled       Boolean         @default(true)
  quietStart      String?
  quietEnd        String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  channel   Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId, notificationType])
  @@index([userId])
  @@index([channelId])
}
